{
  "name": "portal-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "public/main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron-dev": "electron .",
    "electron-build": "npm run build && electron-builder",
    "electron-build-installer": "npm run build && electron-builder --publish never"
  },
  "build": {
    "forceCodeSigning": false,
    "appId": "jp.nakahara131.portal",
    "productName": "社内ポータル",
    "files": [
      "dist/**/*",
      "public/main.js",
      "public/preload.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "社内ポータル"
    },
    "directories": {
      "buildResources": "public",
      "output": "dist/installers"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.25",
    "@types/react-dom": "^18.2.11",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0"
  }
}
